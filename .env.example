# GCP project that hosts the Vertex AI Gemini endpoint.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI region. "global" is supported for Gemini 2.0+ models.
GOOGLE_CLOUD_LOCATION=global

# Tells @google/genai to target Vertex AI instead of the AI Studio API.
GOOGLE_GENAI_USE_VERTEXAI=True

# Port for the local Express API server (proxied at /api in dev).
SERVER_PORT=3001

# Authentication: this app uses Application Default Credentials.
# Run once on the host before `npm run dev`:
#   gcloud auth application-default login
# Do NOT set GEMINI_API_KEY here — AI Studio API keys are not used.
